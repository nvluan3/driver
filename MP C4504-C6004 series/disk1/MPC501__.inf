[Version]
Signature   = "$Windows NT$"
Provider    = %Ricoh%
ClassGUID   = {4D36E979-E325-11CE-BFC1-08002BE10318}
Class       = Printer
DriverVer	= 11/10/2025,3.1.0.0
CatalogFile	= RICOHJBP.cat

[Manufacturer]
%LANIER%=LANIER,NTamd64
%NRG%=NRG,NTamd64
%Ricoh%=Ricoh,NTamd64
%SAVIN%=SAVIN,NTamd64


;WindowsXP(amd64)
[LANIER.NTamd64]
"LANIER MP C501 PCL 6"=LANIER_MP_C501_64.dat,USBPRINT\LANIERMP_C50159C9,LPTENUM\LANIERMP_C50159C9,LANIERMP_C50159C9

[NRG.NTamd64]
"NRG MP C501 PCL 6"=NRG_MP_C501_64.dat,USBPRINT\NRGMP_C501BB02,LPTENUM\NRGMP_C501BB02,NRGMP_C501BB02

[Ricoh.NTamd64]
"RICOH MP C501 PCL 6"=RICOH_MP_C501_64.dat,USBPRINT\RICOHMP_C5016B07,LPTENUM\RICOHMP_C5016B07,RICOHMP_C5016B07

[SAVIN.NTamd64]
"SAVIN MP C501 PCL 6"=SAVIN_MP_C501_64.dat,USBPRINT\SAVINMP_C501A769,LPTENUM\SAVINMP_C501A769,SAVINMP_C501A769



[LANIER_MP_C501_64.dat]
CopyFiles	= RPD_FILES,RPD_COMMON,RPD_COMMON_SYS32
DataSection	= RPD_DATA
DataFile	= rica5Pcd.psz
LanguageMonitor	= rica5Plm,rica5Plm.dll

[NRG_MP_C501_64.dat]
CopyFiles	= RPD_FILES,RPD_COMMON,RPD_COMMON_SYS32
DataSection	= RPD_DATA
DataFile	= rica5Pcd.psz
LanguageMonitor	= rica5Plm,rica5Plm.dll

[RICOH_MP_C501_64.dat]
