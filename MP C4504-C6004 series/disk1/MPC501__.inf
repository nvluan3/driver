DataFile	= rica5Pcd.psz
LanguageMonitor	= rica5Plm,rica5Plm.dll

[SAVIN_MP_C501_64.dat]
CopyFiles	= RPD_FILES,RPD_COMMON,RPD_COMMON_SYS32
DataSection	= RPD_DATA
DataFile	= rica5Pcd.psz
LanguageMonitor	= rica5Plm,rica5Plm.dll


[LANIER_MP_C501_64.dat.Services]
AddService = ,0x2

[NRG_MP_C501_64.dat.Services]
AddService = ,0x2

[RICOH_MP_C501_64.dat.Services]
AddService = ,0x2

[SAVIN_MP_C501_64.dat.Services]
