	font-size:80%;
	margin-bottom:16px;
	text-align:Right;
	color:#FFFFFF;
}
/*-----------------------------------------------------------------------------------------------*/
div.h1{
	padding:32px 0 2px 8px;
	border-bottom:Solid 1px #4682B4;
