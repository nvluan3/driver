	font-size:120%;
	margin-bottom:16px;
	vertical-align:Bottom;
	text-align:Left;
	color:#000080;
	position:Relative;
}
div.h1 a{
	position:Absolute;
	*position:Static!important;
}
/*-----------------------------------------------------------------------------------------------*/
div.h2,
div.h2_2line,
div.h2_3line{
