	text-decoration:None;
}
html{
	border:0;
}
body{
	margin:0;
	padding:0;
	background:#FFFFFF;
}
span{
	color:Inherit;
}
div#id_content a{
	text-decoration:None;
}
div#id_content a:link{
	color:#3366A5;
	text-decoration:None;
}
