	background:#F3F8FA;
	border-bottom:Solid 1px #87CEEB;
	color:#000080;
}
div.h3 a{
	font-weight:Bold;
	text-decoration:None;
	color:#0000FF;
}
div.h3 img{
	vertical-align:Middle;
	margin-right:2px;
	margin-left:0px;
}
/*-----------------------------------------------------------------------------------------------*/
div.h4{
	margin:20px 10px 5px 10px;
