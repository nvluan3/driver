}
/*-----------------------------------------------------------------------------------------------*/
div.chapter_title{
	background:#4682B4;
	padding:2px 5px 2px 5px;
	border-bottom:Solid 1px #4682B4;
	font-weight:Bold;
	font-size:80%;
	margin-bottom:16px;
	text-align:Right;
	color:#FFFFFF;
}
/*-----------------------------------------------------------------------------------------------*/
div.h1{
	padding:32px 0 2px 8px;
	border-bottom:Solid 1px #4682B4;
	background:#F3F8FA;
	font-weight:Bold;
	font-size:120%;
	margin-bottom:16px;
	vertical-align:Bottom;
	text-align:Left;
	color:#000080;
	position:Relative;
}
div.h1 a{
	position:Absolute;
	*position:Static!important;
}
/*-----------------------------------------------------------------------------------------------*/
div.h2,
