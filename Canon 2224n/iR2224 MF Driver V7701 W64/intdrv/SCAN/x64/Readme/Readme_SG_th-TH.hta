}
/*-----------------------------------------------------------------------------------------------*/
div.chapter_title{
	background:#4682B4;
	padding:2px 5px 2px 5px;
	border-bottom:Solid 1px #4682B4;
	font-weight:Bold;
	font-size:80%;
