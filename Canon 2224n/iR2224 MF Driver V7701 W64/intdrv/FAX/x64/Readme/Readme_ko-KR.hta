	white-space:Nowrap;
}
span.superscript{
	vertical-align:Super;
	font-size:80%;
}
span.subscript{
	vertical-align:Sub;
	font-size:80%;
}
span.underline{
	text-decoration:Underline;
}
span.color_white{
	color:#FFFFFF;
}
span.color_blue{
	color:#0000FF;
}
span.color_red{
	color:#FF0000;
}
span.color_orange{
	color:#FFA500;
}
span.color_green{
	color:#008000;
}
