div.open_close_all{
	font-size:80%;
	margin:5px 10px 5px 30px;
	color:#3366A5;
	text-align:Right;
}
div.open_close_next_sibling{
	font-size:80%;
	margin:5px 10px 5px 30px;
	color:#3366A5;
	text-align:Right;
}
