	font-size:80%;
	text-align:Right;
}
div.invisible_end{
	color:#FFFFFF;
	font-size:80%;
	text-align:Right;
}
div.invisible{
	display:None;
	border-right:Dotted 1px #808080;
	margin-right:10px;
}
@media print{
div.open_close_all{
	display:None;
}
div.open_close_next_sibling{
	display:None;
}
div.invisible{
	display:Block;
	border-right:None;
	margin-right:0px;
}}
