	border:None;
	font-size:100%;
	text-align:Left;
	vertical-align:Top;
}
tbody.table_number td.table_number_col_0{
	width:1.5em;
	border:None;
}
tbody.table_number td.table_number_col_0 div{
	margin-left:0px;
	margin-right:0px;
	font-weight:Normal;
	text-align:Right;
}
tbody.table_number td.table_number_col_1{
	width:Auto;
}
