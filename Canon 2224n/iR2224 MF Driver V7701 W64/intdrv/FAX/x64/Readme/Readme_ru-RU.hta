	font-weight:Bold;
}
span.bold\+italic{
	font-style:Italic;
	font-weight:Bold;
}
span.bold\+superscript{
	vertical-align:Super;
	font-size:80%;
	font-weight:Bold;
}
span.bold\+underline{
	text-decoration:Underline;
	font-weight:Bold;
}
span.italic\+superscript{
