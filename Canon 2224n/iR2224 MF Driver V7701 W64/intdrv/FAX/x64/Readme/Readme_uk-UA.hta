a.close_all:hover,
a.open_next_sibling:hover,
a.close_next_sibling:hover{
	border-bottom:Solid 1px #3366A5;
}
a.open_all,
a.close_all,
a.open_next_sibling,
a.close_next_sibling{
	border-bottom:Dotted 1px #3366A5;
	padding-right:15px;
}
a.open_all{
	margin-right:5px;
}
a.open_next_sibling{
}
a.close_all,
a.close_next_sibling{
}
div.invisible_begin{
	color:#FFFFFF;
	font-size:80%;
	text-align:Right;
}
div.invisible_end{
	color:#FFFFFF;
	font-size:80%;
	text-align:Right;
}
div.invisible{
	display:None;
	border-right:Dotted 1px #808080;
	margin-right:10px;
}
@media print{
div.open_close_all{
	display:None;
}
div.open_close_next_sibling{
	display:None;
}
div.invisible{
	display:Block;
	border-right:None;
	margin-right:0px;
}}
