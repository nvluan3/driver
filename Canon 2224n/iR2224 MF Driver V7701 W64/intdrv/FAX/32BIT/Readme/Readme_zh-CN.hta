	margin-right:5px;
}
a.open_next_sibling{
}
a.close_all,
a.close_next_sibling{
}
div.invisible_begin{
	color:#FFFFFF;
	font-size:80%;
	text-align:Right;
}
div.invisible_end{
	color:#FFFFFF;
	font-size:80%;
	text-align:Right;
}
