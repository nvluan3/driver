	margin:0px 5px;
}
div#id_breadcrumbs a:link{
	color:#0000FF;
}
div#id_breadcrumbs a:visited{
	color:#0000FF;
}
span.style_name{
	font:Normal 8pt "Tahoma";
	color:#FF0000;
	margin:0px 5px;
}
div.open_close_all{
	font-size:80%;
	margin:5px 30px 5px 10px;
	color:#3366A5;
	text-align:Left;
}
div.open_close_next_sibling{
	font-size:80%;
	margin:5px 30px 5px 10px;
	color:#3366A5;
	text-align:Left;
}
div#id_content div.open_close_all a:hover,
div#id_content div.open_close_next_sibling a:hover{
	text-decoration:None;
}
a.open_all:hover,
a.close_all:hover,
a.open_next_sibling:hover,
a.close_next_sibling:hover{
	border-bottom:Solid 1px #3366A5;
}
a.open_all,
a.close_all,
a.open_next_sibling,
a.close_next_sibling{
	border-bottom:Dotted 1px #3366A5;
	padding-Left:15px;
}
a.open_all{
	margin-Left:5px;
	background-position: right;
}
a.open_next_sibling{
	background-position: right;
}
a.close_all,
a.close_next_sibling{
	background-position: right;
}
div.invisible_begin{
	color:#FFFFFF;
	font-size:80%;
	text-align:Left;
	background-position: right;
}
div.invisible_end{
	color:#FFFFFF;
	font-size:80%;
	text-align:Left;
	background-position: right;
}
div.invisible{
	display:None;
	border-Left:Dotted 1px #808080;
	margin-Left:10px;
}
@media print{
div.open_close_all{
	display:None;
}
div.open_close_next_sibling{
	display:None;
}
div.invisible{
	display:Block;
	border-Left:None;
	margin-Left:0px;
}}
div.hr{
