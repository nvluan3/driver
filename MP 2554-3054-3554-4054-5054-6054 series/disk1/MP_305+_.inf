[Ricoh.NTamd64]
"RICOH MP 305+ PCL 6"=RICOH_MP_305+_64.dat,USBPRINT\RICOHMP_305+518C,LPTENUM\RICOHMP_305+518C,RICOHMP_305+518C

[SAVIN.NTamd64]
