[Version]
Signature   = "$Windows NT$"
Provider    = %Ricoh%
ClassGUID   = {4D36E979-E325-11CE-BFC1-08002BE10318}
Class       = Printer
DriverVer	= 11/10/2025,3.1.0.0
CatalogFile	= RICOHJBP.cat

[Manufacturer]
%Gestetner%=Gestetner,NTamd64
%infotec%=infotec,NTamd64
%LANIER%=LANIER,NTamd64
%NRG%=NRG,NTamd64
%Ricoh%=Ricoh,NTamd64
%SAVIN%=SAVIN,NTamd64


;WindowsXP(amd64)
[Gestetner.NTamd64]
"Gestetner MP 305+ PCL 6"=Gestetner_MP_305+_64.dat,USBPRINT\GestetnerMP_305+203E,LPTENUM\GestetnerMP_305+203E,GestetnerMP_305+203E

[infotec.NTamd64]
"infotec MP 305+ PCL 6"=infotec_MP_305+_64.dat,USBPRINT\infotecMP_305+1DE3,LPTENUM\infotecMP_305+1DE3,infotecMP_305+1DE3

[LANIER.NTamd64]
"LANIER MP 305+ PCL 6"=LANIER_MP_305+_64.dat,USBPRINT\LANIERMP_305+0343,LPTENUM\LANIERMP_305+0343,LANIERMP_305+0343,LANIERMP_305+_343

[NRG.NTamd64]
